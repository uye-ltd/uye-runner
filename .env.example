GITHUB_TOKEN=ghp_...        # Classic PAT with admin:org, manage_runners:org, read:packages scopes
GITHUB_ORG=your-org
RUNNER_NAME=                # optional; defaults to container hostname
RUNNER_LABELS=self-hosted,linux,x64

# ---- autodeploy (set these as GitHub Actions secrets, not in .env) ----
# DEPLOY_HOST=your-server-ip
# DEPLOY_USER=ubuntu
# DEPLOY_SSH_KEY=<private key PEM>
